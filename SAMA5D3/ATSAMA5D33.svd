                     </field>
                     <field>
                        <name>LQOSEN3</name>
                        <description>Latency Quality of Service Enable for Master 3</description>
                        <bitOffset>14</bitOffset>
                        <bitWidth>1</bitWidth>
                     </field>
                     <field>
                        <name>M4PR</name>
