            <cluster>
               <dim>256</dim>
               <dimIncrement>0x10</dimIncrement>
               <name>REGIONS[%s]</name>
               <description/>
               <addressOffset>0x1000</addressOffset>
               <register>
                  <name>RCTRL_BLOCK_MODE</name>
                  <description>Region Control</description>
                  <addressOffset>0x0</addressOffset>
                  <size>32</size>
                  <access>write-only</access>
                  <resetValue>0x00000000</resetValue>
                  <fields>
                     <field>
                        <name>ARG</name>
                        <description>Command Argument (Block ID)</description>
                        <bitOffset>0</bitOffset>
                        <bitWidth>5</bitWidth>
                     </field>
                     <field>
                        <name>CMD</name>
                        <description>Command</description>
                        <bitOffset>24</bitOffset>
                        <bitWidth>8</bitWidth>
                        <enumeratedValues>
                           <name>CMDSelect</name>
                           <enumeratedValue>
                              <name>CLRNONSEC</name>
                              <description>Clear IDAU region x Non-Secure State of block ARG (RSTATUSB[x].NONSEC[ARG]=0)</description>
                              <value>0x5A</value>
                           </enumeratedValue>
                           <enumeratedValue>
                              <name>SETNONSEC</name>
                              <description>Set IDAU region x Non-Secure State of block ARG (RSTATUSB[x].NONSEC[ARG]=1)</description>
                              <value>0x5B</value>
                           </enumeratedValue>
                        </enumeratedValues>
                     </field>
                  </fields>
               </register>
               <register>
                  <name>RCTRL_WATERMARK_MODE</name>
