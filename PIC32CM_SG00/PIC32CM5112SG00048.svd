                              <value>0x5C</value>
                           </enumeratedValue>
                        </enumeratedValues>
                     </field>
                  </fields>
               </register>
               <register>
                  <name>RSTATUSA</name>
                  <description>Region Status A</description>
                  <addressOffset>0x4</addressOffset>
                  <size>32</size>
                  <access>read-only</access>
                  <resetValue>0x00000000</resetValue>
                  <fields>
                     <field>
                        <name>TYPE</name>
                        <description>IDAU Region Type</description>
                        <bitOffset>0</bitOffset>
                        <bitWidth>4</bitWidth>
                        <enumeratedValues>
                           <name>TYPESelect</name>
                           <enumeratedValue>
                              <name>INVALID</name>
                              <description>Region is invalid</description>
                              <value>0x0</value>
                           </enumeratedValue>
                           <enumeratedValue>
                              <name>SEC</name>
                              <description>Region is secure</description>
                              <value>0x1</value>
                           </enumeratedValue>
                           <enumeratedValue>
                              <name>NONSEC</name>
                              <description>Region is non secure</description>
                              <value>0x2</value>
                           </enumeratedValue>
                           <enumeratedValue>
                              <name>NONSEC_W</name>
                              <description>Region is non secure, the associated register group implements a watermark configuration</description>
                              <value>0x3</value>
                           </enumeratedValue>
                           <enumeratedValue>
                              <name>SECnNONSEC_B</name>
                              <description>Region is either secure or non-secure, the associated register group implements a block configuration</description>
                              <value>0x4</value>
                           </enumeratedValue>
                           <enumeratedValue>
                              <name>SECnNONSEC_L</name>
                              <description>Region is either secure or non-secure, configuration is linked to another IDAU region configuration bit (the linked configuration bit identification info is readable from the RSTATUSC register inside the same register group)</description>
                              <value>0x5</value>
                           </enumeratedValue>
                           <enumeratedValue>
                              <name>NSC_W</name>
                              <description>Region is non-secure callable, the associated register group implements a watermark configuration</description>
                              <value>0x6</value>
                           </enumeratedValue>
                           <enumeratedValue>
                              <name>EXEMPT_B</name>
                              <description>Region is exempt from security, the associated register group implements a block configuration</description>
                              <value>0x7</value>
                           </enumeratedValue>
                        </enumeratedValues>
                     </field>
                     <field>
                        <name>GRAN</name>
                        <description>Region Granularity</description>
                        <bitOffset>8</bitOffset>
                        <bitWidth>6</bitWidth>
                        <enumeratedValues>
                           <name>GRANSelect</name>
                           <enumeratedValue>
                              <name>GRAN_NA</name>
                              <description>Not Applicable</description>
                              <value>0x0</value>
                           </enumeratedValue>
                           <enumeratedValue>
                              <name>GRAN_32B</name>
                              <value>0x5</value>
                           </enumeratedValue>
                           <enumeratedValue>
                              <name>GRAN_64B</name>
                              <value>0x6</value>
                           </enumeratedValue>
                           <enumeratedValue>
                              <name>GRAN_128B</name>
                              <value>0x7</value>
                           </enumeratedValue>
                           <enumeratedValue>
                              <name>GRAN_256B</name>
                              <value>0x8</value>
                           </enumeratedValue>
                           <enumeratedValue>
                              <name>GRAN_512B</name>
                              <value>0x9</value>
                           </enumeratedValue>
                           <enumeratedValue>
                              <name>GRAN_1KB</name>
                              <value>0xA</value>
                           </enumeratedValue>
                           <enumeratedValue>
                              <name>GRAN_2KB</name>
                              <value>0xB</value>
                           </enumeratedValue>
                           <enumeratedValue>
                              <name>GRAN_4KB</name>
                              <value>0xC</value>
                           </enumeratedValue>
                           <enumeratedValue>
                              <name>GRAN_8KB</name>
                              <value>0xD</value>
                           </enumeratedValue>
                           <enumeratedValue>
                              <name>GRAN_16KB</name>
                              <value>0xE</value>
                           </enumeratedValue>
                           <enumeratedValue>
                              <name>GRAN_32KB</name>
                              <value>0xF</value>
                           </enumeratedValue>
                           <enumeratedValue>
                              <name>GRAN_64KB</name>
                              <value>0x10</value>
                           </enumeratedValue>
                           <enumeratedValue>
                              <name>GRAN_128KB</name>
                              <value>0x11</value>
                           </enumeratedValue>
