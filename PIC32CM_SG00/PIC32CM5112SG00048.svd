                           <enumeratedValue>
                              <name>GRAN_2GB</name>
                              <value>0x1F</value>
                           </enumeratedValue>
                           <enumeratedValue>
                              <name>GRAN_4GB</name>
                              <value>0x20</value>
                           </enumeratedValue>
                        </enumeratedValues>
                     </field>
                     <field>
                        <name>MAXSZ</name>
                        <description>Command Argument Maximum Size</description>
                        <bitOffset>16</bitOffset>
                        <bitWidth>6</bitWidth>
                     </field>
                  </fields>
               </register>
               <register>
                  <name>RSTATUSB_BLOCK_MODE</name>
                  <description>Region Status B</description>
                  <addressOffset>0x8</addressOffset>
                  <size>32</size>
                  <access>read-only</access>
                  <resetValue>0x00000000</resetValue>
                  <fields>
                     <field>
                        <name>NONSEC</name>
                        <description>Block Based Region Non-Secure State</description>
                        <bitOffset>0</bitOffset>
                        <bitWidth>32</bitWidth>
                     </field>
                  </fields>
               </register>
               <register>
                  <name>RSTATUSB_WATERMARK_MODE</name>
                  <description>Region Status B</description>
                  <alternateRegister>RSTATUSB_BLOCK_MODE</alternateRegister>
                  <addressOffset>0x8</addressOffset>
                  <size>32</size>
                  <access>read-only</access>
                  <resetValue>0x00000000</resetValue>
                  <fields>
