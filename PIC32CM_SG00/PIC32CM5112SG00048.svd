                              <name>GRAN_8MB</name>
                              <value>0x17</value>
                           </enumeratedValue>
                           <enumeratedValue>
                              <name>GRAN_16MB</name>
                              <value>0x18</value>
                           </enumeratedValue>
                           <enumeratedValue>
                              <name>GRAN_32MB</name>
                              <value>0x19</value>
                           </enumeratedValue>
                           <enumeratedValue>
                              <name>GRAN_64MB</name>
                              <value>0x1A</value>
                           </enumeratedValue>
                           <enumeratedValue>
                              <name>GRAN_128MB</name>
                              <value>0x1B</value>
                           </enumeratedValue>
                           <enumeratedValue>
                              <name>GRAN_256MB</name>
                              <value>0x1C</value>
                           </enumeratedValue>
                           <enumeratedValue>
                              <name>GRAN_512MB</name>
                              <value>0x1D</value>
                           </enumeratedValue>
                           <enumeratedValue>
                              <name>GRAN_1GB</name>
                              <value>0x1E</value>
