                  <field>
                     <name>FieldF</name>
                     <description>'0': Field is GF(p) '1': Field is GF(2**m)</description>
                     <bitOffset>7</bitOffset>
                     <bitWidth>1</bitWidth>
                  </field>
                  <field>
                     <name>OpBytesM1</name>
                     <description>This field defines the size (= number of bytes minus one) of the operands for the current operation. Possible values are limited by the maximum supported operand size. Examples: - 0x014 -&gt; ECC on curve K-163 - 0x01F -&gt; ECC on curve P-256 - 0x02F -&gt; ECC on curve P-384 - 0x033 -&gt; ECC on curve K-409 - 0x041 -&gt; ECC on curve P-521 - 0x07F -&gt; 1024-bit RSA - 0x09F -&gt; 1280-bit RSA - 0x1FF -&gt; 4096-bit RSA - 0x3FF -&gt; 8192-bit RSA</description>
                     <bitOffset>8</bitOffset>
                     <bitWidth>10</bitWidth>
                  </field>
                  <field>
                     <name>RandMod</name>
                     <description>Enable randomization of modulus (counter-measure).</description>
                     <bitOffset>19</bitOffset>
                     <bitWidth>1</bitWidth>
                  </field>
                  <field>
                     <name>SelCurve</name>
                     <description>Enable accelerator for specific curve modulus: 0x0: No acceleration (default) 0x1: P256 0x2: P384 0x3: P521 0x4: P192 0x5: Curve25519 0x6: Ed25519 This field has no effect when the optional acceleration hardware is not included.</description>
                     <bitOffset>20</bitOffset>
                     <bitWidth>3</bitWidth>
                  </field>
                  <field>
                     <name>RandKE</name>
                     <description>Enable randomization of exponent/scalar (counter-measure).</description>
                     <bitOffset>24</bitOffset>
                     <bitWidth>1</bitWidth>
                  </field>
                  <field>
                     <name>RandProj</name>
                     <description>Enable randomization of projective coordinates (counter-measure).</description>
                     <bitOffset>25</bitOffset>
                     <bitWidth>1</bitWidth>
                  </field>
                  <field>
                     <name>Edwards</name>
                     <description>Enable Edwards curve (see operation description).</description>
                     <bitOffset>26</bitOffset>
                     <bitWidth>1</bitWidth>
                  </field>
                  <field>
                     <name>SwapBytes</name>
                     <description>Swap the bytes on AHB interface: '0': Native format (little endian) '1': Byte swapped (big endian) See also section 4.2.1. This bit must be programmed before writing/reading any data in data memory.</description>
                     <bitOffset>28</bitOffset>
                     <bitWidth>1</bitWidth>
                  </field>
                  <field>
                     <name>FlagA</name>
                     <description>See operation description.</description>
                     <bitOffset>29</bitOffset>
                     <bitWidth>1</bitWidth>
                  </field>
                  <field>
                     <name>FlagB</name>
                     <description>See operation description.</description>
                     <bitOffset>30</bitOffset>
                     <bitWidth>1</bitWidth>
                  </field>
                  <field>
                     <name>CalcR2</name>
                     <description>This bit indicates if the IP has to calculate R**2 mod N for the next operation. This bit must be set to '1' when a new prime number has been programmed. This bit is used for primitive operations and ignored for the other operations. '0': don't recalculate R**2 mod N '1': re-calculate R**2 mod N</description>
                     <bitOffset>31</bitOffset>
                     <bitWidth>1</bitWidth>
                  </field>
               </fields>
            </register>
            <register>
               <name>PK_Registers__Control</name>
               <description>Command register.</description>
               <addressOffset>0x12008</addressOffset>
               <size>32</size>
               <access>write-only</access>
               <resetValue>0x00000000</resetValue>
               <fields>
                  <field>
                     <name>Start</name>
                     <description>Writing a '1' starts the processing.</description>
                     <bitOffset>0</bitOffset>
                     <bitWidth>1</bitWidth>
                  </field>
                  <field>
                     <name>ClearIRQ</name>
                     <description>Writing a '1' clears the IRQ output.</description>
                     <bitOffset>1</bitOffset>
                     <bitWidth>1</bitWidth>
                  </field>
               </fields>
            </register>
            <register>
               <name>PK_Registers__Status</name>
               <description>Status register.</description>
               <addressOffset>0x1200C</addressOffset>
               <size>32</size>
               <access>read-only</access>
               <resetValue>0x00000000</resetValue>
               <fields>
                  <field>
                     <name>ErrorFlags</name>
                     <description>These bits indicate an error condition. They are updated at the end of the operation. They are cleared when starting a new operation. See documentation for more details.</description>
                     <bitOffset>4</bitOffset>
                     <bitWidth>12</bitWidth>
                  </field>
                  <field>
                     <name>PK_Busy</name>
                     <description>This bit reflects the BUSY output value. It is set when the operation starts and it is cleared when the operation is finished.</description>
                     <bitOffset>16</bitOffset>
                     <bitWidth>1</bitWidth>
                  </field>
                  <field>
                     <name>IntrptStatus</name>
                     <description>This bit reflects the IRQ output value. It is set when the operation is finished. It is cleared when the CPU writes the bit 1 of Control Register.</description>
                     <bitOffset>17</bitOffset>
                     <bitWidth>1</bitWidth>
                  </field>
                  <field>
                     <name>FailPtr</name>
                     <description>These bits indicate which data location generated the error flag. They are not available for all error flags.</description>
                     <bitOffset>24</bitOffset>
                     <bitWidth>5</bitWidth>
                  </field>
               </fields>
            </register>
            <register>
               <name>PK_Registers__Timer</name>
               <description>Timer register.</description>
               <addressOffset>0x12014</addressOffset>
               <size>32</size>
               <resetValue>0x00000000</resetValue>
               <fields>
                  <field>
                     <name>Timer</name>
                     <description>Number of core clock cycles.</description>
                     <bitOffset>1</bitOffset>
                     <bitWidth>31</bitWidth>
                  </field>
               </fields>
            </register>
            <register>
               <name>PK_Registers__HwConfig</name>
               <description>Hardware configuration register.</description>
               <addressOffset>0x12018</addressOffset>
               <size>32</size>
               <access>read-only</access>
               <resetValue>0x43F30200</resetValue>
               <fields>
                  <field>
                     <name>MaxOpSize</name>
                     <description>Maximum operand size (number of bytes).</description>
                     <bitOffset>0</bitOffset>
                     <bitWidth>12</bitWidth>
                  </field>
                  <field>
                     <name>NbMult</name>
                     <description>Number of multipliers: 0x0: 1 multiplier 0x1: 4 multipliers 0x2: 16 multipliers 0x4: 64 multipliers 0x8: 256 multipliers</description>
                     <bitOffset>12</bitOffset>
                     <bitWidth>4</bitWidth>
                  </field>
                  <field>
                     <name>PrimeField</name>
                     <description>Support prime field.</description>
                     <bitOffset>16</bitOffset>
                     <bitWidth>1</bitWidth>
                  </field>
                  <field>
                     <name>BinaryField</name>
                     <description>Support binary field.</description>
                     <bitOffset>17</bitOffset>
                     <bitWidth>1</bitWidth>
                  </field>
                  <field>
                     <name>ECC</name>
                     <description>Support RAM error correction.</description>
                     <bitOffset>18</bitOffset>
                     <bitWidth>1</bitWidth>
                  </field>
                  <field>
                     <name>P256</name>
                     <description>Support ECC P256 acceleration.</description>
                     <bitOffset>20</bitOffset>
                     <bitWidth>1</bitWidth>
                  </field>
                  <field>
                     <name>P384</name>
                     <description>Support ECC P384 acceleration.</description>
                     <bitOffset>21</bitOffset>
                     <bitWidth>1</bitWidth>
                  </field>
                  <field>
                     <name>P521</name>
                     <description>Support ECC P521 acceleration.</description>
                     <bitOffset>22</bitOffset>
                     <bitWidth>1</bitWidth>
                  </field>
                  <field>
                     <name>P192</name>
                     <description>Support ECC P192 acceleration.</description>
                     <bitOffset>23</bitOffset>
                     <bitWidth>1</bitWidth>
                  </field>
                  <field>
                     <name>X25519</name>
                     <description>Support Curve25519/Ed25519 acceleration.</description>
                     <bitOffset>24</bitOffset>
                     <bitWidth>1</bitWidth>
                  </field>
                  <field>
                     <name>AHBMaster</name>
                     <description>'0': Memory access through AHB Slave and internally in the PKE.                                                                             '1': Memory access through AHB Master, outside the PKE.</description>
                     <bitOffset>25</bitOffset>
                     <bitWidth>1</bitWidth>
                  </field>
                  <field>
                     <name>DisableSM</name>
                     <description>State of DisableSMx input (high when SM2/SM9 operations are disabled).</description>
                     <bitOffset>29</bitOffset>
                     <bitWidth>1</bitWidth>
                  </field>
                  <field>
                     <name>DisableClrMem</name>
                     <description>State of DisableClrMem input (high when automatic clear of the RAM after reset is disabled).</description>
                     <bitOffset>30</bitOffset>
                     <bitWidth>1</bitWidth>
                  </field>
                  <field>
                     <name>DisableCM</name>
                     <description>State of DisableCM input (high when counter-measures are disabled).</description>
                     <bitOffset>31</bitOffset>
                     <bitWidth>1</bitWidth>
                  </field>
               </fields>
            </register>
            <register>
               <name>PK_Registers__OpSize</name>
               <description>Operand size register.</description>
               <addressOffset>0x1201C</addressOffset>
               <size>32</size>
               <resetValue>0x00001000</resetValue>
               <fields>
                  <field>
                     <name>OpSize</name>
                     <description>Operand size (number of bytes): 0x0100: 256 0x0209: 521 0x0800: 2048 0x0C00: 3072 0x1000: 4096 This register is used when the memory is accessed via AHB Master</description>
                     <bitOffset>0</bitOffset>
                     <bitWidth>13</bitWidth>
                  </field>
               </fields>
            </register>
            <register>
               <name>PK_Registers__MemOffset</name>
               <description>Memory offset register.</description>
               <addressOffset>0x12020</addressOffset>
               <size>32</size>
               <resetValue>0x00000000</resetValue>
               <fields>
                  <field>
                     <name>MemOffset</name>
                     <description>Memory offset for AHB Master</description>
                     <bitOffset>0</bitOffset>
                     <bitWidth>32</bitWidth>
                  </field>
               </fields>
            </register>
            <register>
               <name>PK_Registers__MicroCodeOffset</name>
               <description>MicroCode offset register.</description>
               <addressOffset>0x12024</addressOffset>
               <size>32</size>
               <resetValue>0x00000000</resetValue>
               <fields>
                  <field>
                     <name>MicroCodeOffset</name>
                     <description>MicroCode offset for AHB Master</description>
                     <bitOffset>0</bitOffset>
                     <bitWidth>32</bitWidth>
                  </field>
               </fields>
            </register>
         </registers>
      </peripheral>
      <peripheral>
         <name>ICB</name>
         <version>SYSTEM_IP1.0.0</version>
         <description>Implementation Control Block</description>
         <baseAddress>0xE000E000</baseAddress>
