                  </field>
                  <field>
                     <name>CRCERR</name>
                     <description>CRC Error Flag</description>
                     <bitOffset>9</bitOffset>
                     <bitWidth>1</bitWidth>
                     <enumeratedValues>
                        <name>CRCERRSelect</name>
                        <enumeratedValue>
