               <fields>
                  <field>
                     <name>LVDET</name>
                     <description>Low Voltage Detector Interrupt Enable</description>
                     <bitOffset>0</bitOffset>
                     <bitWidth>1</bitWidth>
                  </field>
                  <field>
                     <name>LVDRDY</name>
                     <description>Low Voltage Detector Ready Interrupt Enable</description>
                     <bitOffset>1</bitOffset>
                     <bitWidth>1</bitWidth>
                  </field>
                  <field>
                     <name>ULDORDY</name>
                     <description>User LDO Regulator Ready Interrupt Enable</description>
                     <bitOffset>2</bitOffset>
                     <bitWidth>1</bitWidth>
                  </field>
                  <field>
                     <name>ULDOOVHEAT</name>
