                     <bitWidth>1</bitWidth>
                  </field>
                  <field>
                     <name>BORVDDUSB</name>
                     <description>BORVDDUSB Status. One if VDDUSB is OK. It corresponds to bor_vddusb_n_mv signal of SMOR.</description>
                     <bitOffset>5</bitOffset>
                     <bitWidth>1</bitWidth>
                  </field>
                  <field>
                     <name>ADDVREGRDY0</name>
