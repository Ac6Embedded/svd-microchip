                     <bitWidth>1</bitWidth>
                     <enumeratedValues>
                        <name>RUNSTDBYSelect</name>
                        <enumeratedValue>
                           <name>0</name>
                           <description>HSM clock is disabled in Standby Sleep mode, clock requests are de-asserted after any pending bus transactions or requests are completed.</description>
                           <value>0</value>
                        </enumeratedValue>
                        <enumeratedValue>
                           <name>1</name>
                           <description>If enabled, the HSM clock remains requested in Standby Sleep mode.</description>
                           <value>1</value>
                        </enumeratedValue>
                     </enumeratedValues>
