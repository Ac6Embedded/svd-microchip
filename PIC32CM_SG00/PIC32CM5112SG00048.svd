            <register>
               <name>CTRLA</name>
               <description>CTRL A REGISTER</description>
               <addressOffset>0x0</addressOffset>
               <size>32</size>
               <resetValue>0x00008000</resetValue>
               <fields>
                  <field>
                     <name>PRIV</name>
                     <description>Privileged Access Only</description>
                     <bitOffset>2</bitOffset>
                     <bitWidth>1</bitWidth>
                     <enumeratedValues>
                        <name>PRIVSelect</name>
                        <enumeratedValue>
                           <name>DISABLE</name>
                           <description>Macro register accessible in privileged and unprivileged accesses.</description>
                           <value>0</value>
                        </enumeratedValue>
                        <enumeratedValue>
                           <name>ENABLE</name>
                           <description>Macro registers only accessible in privileged accesses</description>
                           <value>1</value>
                        </enumeratedValue>
                     </enumeratedValues>
                  </field>
                  <field>
                     <name>FWS</name>
                     <description>Flash Access Time Defined in terms of AHB Clock Wait States</description>
                     <bitOffset>8</bitOffset>
                     <bitWidth>4</bitWidth>
                     <enumeratedValues>
                        <name>FWSSelect</name>
                        <enumeratedValue>
                           <name>0</name>
                           <description>Zero Wait States</description>
                           <value>0</value>
                        </enumeratedValue>
                        <enumeratedValue>
                           <name>1</name>
                           <description>One Wait State</description>
                           <value>1</value>
                        </enumeratedValue>
                        <enumeratedValue>
                           <name>14</name>
                           <description>Fourteen Wait States</description>
                           <value>14</value>
                        </enumeratedValue>
                        <enumeratedValue>
                           <name>15</name>
                           <description>Fifteen Wait States</description>
                           <value>15</value>
                        </enumeratedValue>
                     </enumeratedValues>
                  </field>
                  <field>
                     <name>ADRWS</name>
                     <description>Address Wait State Enable</description>
                     <bitOffset>14</bitOffset>
                     <bitWidth>1</bitWidth>
                     <enumeratedValues>
                        <name>ADRWSSelect</name>
                        <enumeratedValue>
                           <name>ZERO</name>
                           <description>Add 0 Address Wait States - allowing for higher performance at lower clock frequencies</description>
                           <value>0</value>
                        </enumeratedValue>
                        <enumeratedValue>
                           <name>ONE</name>
                           <description>Add 1 Address Wait State - allowing for higher clock frequencies</description>
                           <value>1</value>
                        </enumeratedValue>
                     </enumeratedValues>
                  </field>
                  <field>
                     <name>AUTOWS</name>
                     <description>Automatic Wait State Enable.</description>
                     <bitOffset>15</bitOffset>
                     <bitWidth>1</bitWidth>
                     <enumeratedValues>
                        <name>AUTOWSSelect</name>
                        <enumeratedValue>
                           <name>DISABLE</name>
                           <description>Use FWS: Total flash wait states are ADRWS + FWS</description>
                           <value>0</value>
                        </enumeratedValue>
                        <enumeratedValue>
                           <name>ENABLE</name>
                           <description>Use Automatic wait states: Total flash wait states are ADRWS + Taws</description>
                           <value>1</value>
                        </enumeratedValue>
                     </enumeratedValues>
                  </field>
                  <field>
                     <name>RDBUFWS</name>
                     <description>Read Buffer Wait StatesPer AHB port control of deterministic or zero wait state read buffer access.</description>
                     <bitOffset>16</bitOffset>
                     <bitWidth>1</bitWidth>
                     <enumeratedValues>
                        <name>RDBUFWSSelect</name>
                        <enumeratedValue>
                           <name>ZEROWS</name>
                           <description>0 Wait States</description>
                           <value>0</value>
                        </enumeratedValue>
                        <enumeratedValue>
                           <name>DETERMINISTIC</name>
                           <description>ADRWS + FWS wait state for hits to AHB read buffer</description>
                           <value>1</value>
                        </enumeratedValue>
                     </enumeratedValues>
                  </field>
               </fields>
