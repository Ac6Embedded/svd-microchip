                     <bitWidth>2</bitWidth>
                     <enumeratedValues>
                        <name>SLPSelect</name>
                        <enumeratedValue>
                           <name>MANUAL</name>
                           <description>Maintain state of STATUS.PRM on entry to Standby</description>
                           <value>0</value>
                        </enumeratedValue>
                        <enumeratedValue>
                           <name>RSVD01</name>
                           <description>RSVD</description>
                           <value>1</value>
                        </enumeratedValue>
                        <enumeratedValue>
                           <name>AUTOFAST</name>
                           <description>Enter Flash Hibernate on entry to Standby w/ wakeup to Auto Standby</description>
                           <value>2</value>
                        </enumeratedValue>
                        <enumeratedValue>
                           <name>AUTOSLOW</name>
                           <description>Enter Flash Hibernate on entry to Standby w/ wakeup on first access</description>
                           <value>3</value>
                        </enumeratedValue>
                     </enumeratedValues>
                  </field>
                  <field>
                     <name>CHEDIS</name>
                     <description>Cache Disable</description>
