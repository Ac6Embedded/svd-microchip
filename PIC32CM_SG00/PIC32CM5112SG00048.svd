         <baseAddress>0xE002E000</baseAddress>
      </peripheral>
      <peripheral>
         <name>IDAU</name>
         <version>042503a0</version>
         <description>Implementation Defined Attribution Unit</description>
         <baseAddress>0x44012000</baseAddress>
