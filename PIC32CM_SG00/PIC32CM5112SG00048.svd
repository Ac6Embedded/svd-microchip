                     <enumeratedValues>
                        <name>OVRSAMSelect</name>
                        <enumeratedValue>
                           <name>4_SAMPLES</name>
                           <description>(If FMODE is 0) 4 samples (shift sum 1 bit to right, output data is 13-bits) / (If FMODE is 1) 2 samples to be averaged</description>
                           <value>0</value>
                        </enumeratedValue>
                        <enumeratedValue>
                           <name>16_SAMPLES</name>
                           <description>(If FMODE is 0) 16 samples (shift sum 2 bits to right, output data is 14-bits) / (If FMODE is 1) 4 samples to be averaged</description>
                           <value>1</value>
                        </enumeratedValue>
                        <enumeratedValue>
                           <name>64_SAMPLES</name>
                           <description>(If FMODE is 0) 64 samples (shift sum 3 bits to right, output data is 15-bits) / (If FMODE is 1) 8 samples to be averaged</description>
                           <value>2</value>
                        </enumeratedValue>
                        <enumeratedValue>
                           <name>256_SAMPLES</name>
                           <description>(If FMODE is 0) 256 samples (shift sum 4 bits to right, output data is 16-bits) / (If FMODE is 1) 16 samples to be averaged</description>
                           <value>3</value>
                        </enumeratedValue>
                        <enumeratedValue>
                           <name>2_SAMPLES</name>
                           <description>(If FMODE is 0) 2 samples (shift sum 0 bits to right, output data is 12.1 format) / (If FMODE is 1) 32 samples to be averaged</description>
                           <value>4</value>
                        </enumeratedValue>
                        <enumeratedValue>
                           <name>8_SAMPLES</name>
                           <description>(If FMODE is 0) 8 samples (shift sum 1 bit to right, output data is 13.1 format) / (If FMODE is 1) 64 samples to be averaged</description>
                           <value>5</value>
                        </enumeratedValue>
                        <enumeratedValue>
                           <name>32_SAMPLES</name>
                           <description>(If FMODE is 0) 32 samples (shift sum 2 bits to right, output data is 14.1 format) / (If FMODE is 1) 128 samples to be averaged</description>
                           <value>6</value>
                        </enumeratedValue>
                        <enumeratedValue>
                           <name>128_SAMPLES</name>
                           <description>(If FMODE is 0) 128 samples (shift sum 3 bits to right, output data is 15.1 format) / (If FMODE is 1) 256 samples to be averaged</description>
                           <value>7</value>
                        </enumeratedValue>
                     </enumeratedValues>
