                        <enumeratedValue>
                           <name>ENABLE</name>
                           <description>Predictive Prefetch Enabled</description>
                           <value>0</value>
                        </enumeratedValue>
                        <enumeratedValue>
                           <name>DISABLE</name>
                           <description>Predictive Prefetch Disabled</description>
                           <value>1</value>
                        </enumeratedValue>
                     </enumeratedValues>
                  </field>
