                     <bitWidth>15</bitWidth>
                  </field>
               </fields>
            </register>
            <register>
               <name>MEM_BAR1</name>
               <description>SPI Slave Memory Base Address1 Register.\n</description>
               <addressOffset>0x24</addressOffset>
