            <register>
               <name>BAR_LDI_ACPI_EC3_H0</name>
               <description>ACPI EC Channel 3 Memory BAR</description>
               <addressOffset>0x158</addressOffset>
               <size>32</size>
               <resetValue>0x00000507</resetValue>
               <fields>
