                     <bitOffset>14</bitOffset>
                     <bitWidth>1</bitWidth>
                  </field>
                  <field>
                     <name>OBF_FLG</name>
                     <description>Enable Output Buffer signaling Interrupt to EC.\n</description>
                     <bitOffset>15</bitOffset>
                     <bitWidth>1</bitWidth>
                  </field>
                  <field>
                     <name>SPIM_RST_REQ</name>
                     <description>Enable SPI Master Request Reset Interrupt to EC.\n</description>
                     <bitOffset>16</bitOffset>
                     <bitWidth>1</bitWidth>
                  </field>
                  <field>
                     <name>RXF_RST_DN</name>
                     <description>Enable RX FIFO Reset Done Interrupt to EC.\n</description>
                     <bitOffset>17</bitOffset>
                     <bitWidth>1</bitWidth>
                  </field>
                  <field>
                     <name>TXF_RST_DN</name>
                     <description>Enable TX FIFO Reset Done Interrupt to EC.\n</description>
                     <bitOffset>18</bitOffset>
                     <bitWidth>1</bitWidth>
                  </field>
                  <field>
                     <name>OOL0_ERR</name>
                     <description>Enable Out Of Limit 0 Error Interrupt to EC.\n</description>
                     <bitOffset>19</bitOffset>
                     <bitWidth>1</bitWidth>
                  </field>
                  <field>
                     <name>OOL1_ERR</name>
                     <description>Enable Out Of Limit 1 Error Interrupt to EC.\n</description>
                     <bitOffset>20</bitOffset>
                     <bitWidth>1</bitWidth>
