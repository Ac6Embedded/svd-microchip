                     <bitOffset>23</bitOffset>
                     <bitWidth>1</bitWidth>
                  </field>
                  <field>
                     <name>RXF_SIZE_ERR</name>
                     <description>Enable RX FIFO SIZE Error Interrupt to EC.\n</description>
