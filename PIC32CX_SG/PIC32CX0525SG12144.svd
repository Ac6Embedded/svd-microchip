                  <field>
                     <name>ARMBUS_ERR</name>
                     <description>Enable AHB BUS Error Interrupt to EC.\n</description>
                     <bitOffset>21</bitOffset>
                     <bitWidth>1</bitWidth>
                  </field>
                  <field>
                     <name>UNDEF_CMD_ERR</name>
                     <description>Enable Undefined Command Error Interrupt to EC.\n</description>
