                  <field>
                     <name>MEM_WR_BUSY</name>
                     <description>Enable Memory Write Busy Interrupt to EC.\n</description>
                     <bitOffset>3</bitOffset>
                     <bitWidth>1</bitWidth>
                  </field>
                  <field>
                     <name>MEM_RD_BUSY</name>
