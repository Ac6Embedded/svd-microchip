            <register>
               <name>SPI_IEN</name>
               <description>SPI Slave Interrupt Enable Register.\n</description>
               <addressOffset>0xC</addressOffset>
               <size>32</size>
               <resetValue>0x00000000</resetValue>
               <fields>
                  <field>
                     <name>MEM_WR_DONE</name>
