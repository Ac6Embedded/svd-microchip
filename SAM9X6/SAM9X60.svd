                           <description>1 sector for main area (512 or 1024 bytes)</description>
                           <value>0x0</value>
                        </enumeratedValue>
                        <enumeratedValue>
                           <name>PAGESIZE_2SEC</name>
                           <description>2 sectors for main area (1024 or 2048 bytes)</description>
                           <value>0x1</value>
                        </enumeratedValue>
                        <enumeratedValue>
                           <name>PAGESIZE_4SEC</name>
