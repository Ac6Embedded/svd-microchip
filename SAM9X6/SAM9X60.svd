                     <name>HCIVERSION</name>
                     <description>Host Controller Interface Version Number</description>
                     <bitOffset>16</bitOffset>
                     <bitWidth>16</bitWidth>
                  </field>
               </fields>
            </register>
            <register>
               <name>HCSPARAMS</name>
