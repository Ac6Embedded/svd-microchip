                     <bitWidth>1</bitWidth>
                  </field>
                  <field>
                     <name>LSBHALF</name>
                     <description>Last Bit Half Period Compatibility</description>
                     <bitOffset>8</bitOffset>
                     <bitWidth>1</bitWidth>
                     <writeConstraint>
                        <useEnumeratedValues>true</useEnumeratedValues>
                     </writeConstraint>
                     <enumeratedValues>
                        <name>LSBHALFSelect</name>
                        <enumeratedValue>
                           <name>LSBHALF_0</name>
                           <description>Normal SPI mode of operation: all bits have a 1-bit time duration (standard SPI mode)</description>
                           <value>0</value>
                        </enumeratedValue>
                        <enumeratedValue>
                           <name>LSBHALF_1</name>
                           <description>Compatibility mode when connected to an SPI client having only a half bit period duration time for the last bit of the frame (non-standard SPI mode)</description>
                           <value>1</value>
                        </enumeratedValue>
                     </enumeratedValues>
                  </field>
                  <field>
                     <name>CMPMODE</name>
                     <description>Comparison Mode</description>
                     <bitOffset>12</bitOffset>
                     <bitWidth>1</bitWidth>
