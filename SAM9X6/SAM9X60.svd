      <peripheral>
         <name>UDPHS</name>
         <version>6227Z</version>
         <description>USB High Speed Device Port</description>
         <baseAddress>0xF803C000</baseAddress>
         <addressBlock>
            <offset>0</offset>
            <size>0x370</size>
