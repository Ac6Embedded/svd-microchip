                     <field>
                        <name>MDLC</name>
                        <description>Mailbox Data Length Code</description>
                        <bitOffset>16</bitOffset>
                        <bitWidth>4</bitWidth>
                     </field>
                     <field>
                        <name>MRTR</name>
                        <description>Mailbox Remote Transmission Request</description>
                        <bitOffset>20</bitOffset>
                        <bitWidth>1</bitWidth>
                     </field>
                     <field>
                        <name>MABT</name>
                        <description>Mailbox Message Abort (cleared by writing MTCR or MACR in the CAN_MCRx)</description>
                        <bitOffset>22</bitOffset>
                        <bitWidth>1</bitWidth>
                     </field>
                     <field>
                        <name>MRDY</name>
                        <description>Mailbox Ready (cleared by writing MTCR or MACR in the CAN_MCRx)</description>
                        <bitOffset>23</bitOffset>
                        <bitWidth>1</bitWidth>
                     </field>
                     <field>
                        <name>MMI</name>
                        <description>Mailbox Message Ignored (cleared by reading CAN_MSRx)</description>
                        <bitOffset>24</bitOffset>
                        <bitWidth>1</bitWidth>
                     </field>
                  </fields>
               </register>
               <register>
                  <name>MDL</name>
                  <description>Mailbox Data Low Register</description>
                  <addressOffset>0x14</addressOffset>
                  <fields>
                     <field>
                        <name>MDL</name>
                        <description>Message Data Low Value</description>
                        <bitOffset>0</bitOffset>
                        <bitWidth>32</bitWidth>
                     </field>
                  </fields>
               </register>
               <register>
                  <name>MDH</name>
                  <description>Mailbox Data High Register</description>
                  <addressOffset>0x18</addressOffset>
                  <fields>
                     <field>
                        <name>MDH</name>
                        <description>Message Data High Value</description>
                        <bitOffset>0</bitOffset>
                        <bitWidth>32</bitWidth>
                     </field>
                  </fields>
               </register>
               <register>
                  <name>MCR</name>
                  <description>Mailbox Control Register</description>
                  <addressOffset>0x1C</addressOffset>
                  <access>write-only</access>
                  <fields>
                     <field>
                        <name>MDLC</name>
