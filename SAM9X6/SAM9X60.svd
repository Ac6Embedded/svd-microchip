                  <field>
                     <name>RERR</name>
                     <description>Read Error Interrupt Mask Bit</description>
                     <bitOffset>2</bitOffset>
                     <bitWidth>1</bitWidth>
                  </field>
                  <field>
                     <name>BERR</name>
                     <description>Write Error Interrupt Mask Bit</description>
                     <bitOffset>3</bitOffset>
                     <bitWidth>1</bitWidth>
                  </field>
                  <field>
                     <name>IERR</name>
                     <description>Illegal Instruction Interrupt Mask Bit</description>
                     <bitOffset>4</bitOffset>
                     <bitWidth>1</bitWidth>
                  </field>
               </fields>
            </register>
            <register>
               <name>IS</name>
               <description>Interrupt Status Register</description>
               <addressOffset>0x1C</addressOffset>
               <access>read-only</access>
               <fields>
                  <field>
                     <name>RBEMPTY</name>
                     <description>Ring Buffer Empty Interrupt Status Bit</description>
                     <bitOffset>0</bitOffset>
                     <bitWidth>1</bitWidth>
                  </field>
                  <field>
                     <name>EXEND</name>
                     <description>End of Execution Status Bit</description>
                     <bitOffset>1</bitOffset>
                     <bitWidth>1</bitWidth>
                  </field>
                  <field>
                     <name>RERR</name>
                     <description>Read Error Interrupt Status Bit</description>
                     <bitOffset>2</bitOffset>
                     <bitWidth>1</bitWidth>
                  </field>
                  <field>
                     <name>BERR</name>
                     <description>Write Error Interrupt Status Bit</description>
                     <bitOffset>3</bitOffset>
                     <bitWidth>1</bitWidth>
                  </field>
                  <field>
                     <name>IERR</name>
                     <description>Illegal Instruction Interrupt Status Bit</description>
                     <bitOffset>4</bitOffset>
                     <bitWidth>1</bitWidth>
                  </field>
               </fields>
            </register>
            <cluster>
               <dim>2</dim>
               <dimIncrement>8</dimIncrement>
               <name>GFX2D_SUB0[%s]</name>
               <description/>
               <addressOffset>0x20</addressOffset>
               <register>
                  <name>PC</name>
                  <description>Performance Configuration 0 Register</description>
                  <addressOffset>0x0</addressOffset>
                  <fields>
                     <field>
                        <name>SEL</name>
                        <description>Performance Metrics Selection</description>
                        <bitOffset>0</bitOffset>
                        <bitWidth>2</bitWidth>
                        <writeConstraint>
                           <useEnumeratedValues>true</useEnumeratedValues>
                        </writeConstraint>
                        <enumeratedValues>
                           <name>SELSelect</name>
                           <enumeratedValue>
                              <name>DISABLED</name>
                              <description>The performance counter is disabled and reset.</description>
                              <value>0x0</value>
                           </enumeratedValue>
                           <enumeratedValue>
                              <name>READ</name>
                              <description>The performance counter is incremented when a Read access is performed.</description>
                              <value>0x1</value>
                           </enumeratedValue>
                           <enumeratedValue>
                              <name>WRITE</name>
                              <description>The performance counter is incremented when a Write access is performed.</description>
                              <value>0x2</value>
                           </enumeratedValue>
                           <enumeratedValue>
                              <name>CYCLE</name>
                              <description>Number of clock cycles</description>
                              <value>0x3</value>
                           </enumeratedValue>
                        </enumeratedValues>
                     </field>
                     <field>
                        <name>FILT</name>
                        <description>Filter Configuration</description>
                        <bitOffset>4</bitOffset>
                        <bitWidth>3</bitWidth>
                        <writeConstraint>
                           <useEnumeratedValues>true</useEnumeratedValues>
                        </writeConstraint>
                        <enumeratedValues>
                           <name>FILTSelect</name>
                           <enumeratedValue>
                              <name>DISABLED</name>
                              <description>The filter is disabled.</description>
                              <value>0x0</value>
                           </enumeratedValue>
                           <enumeratedValue>
                              <name>QOS0</name>
                              <description>Events are valid when input QoS is equal to 0.</description>
                              <value>0x1</value>
                           </enumeratedValue>
                           <enumeratedValue>
                              <name>QOS1</name>
                              <description>Events are valid when input QoS is equal to 1.</description>
                              <value>0x2</value>
                           </enumeratedValue>
                           <enumeratedValue>
                              <name>QOS2</name>
                              <description>Events are valid when input QoS is equal to 2.</description>
                              <value>0x3</value>
                           </enumeratedValue>
                           <enumeratedValue>
                              <name>QOS3</name>
                              <description>Events are valid when input QoS is equal to 3.</description>
                              <value>0x4</value>
                           </enumeratedValue>
                        </enumeratedValues>
                     </field>
                  </fields>
               </register>
               <register>
                  <name>MC</name>
                  <description>Metrics Counter 0 Register</description>
                  <addressOffset>0x4</addressOffset>
                  <access>read-only</access>
                  <fields>
                     <field>
                        <name>COUNTER</name>
                        <description>Metrics Counter</description>
                        <bitOffset>0</bitOffset>
                        <bitWidth>32</bitWidth>
                     </field>
                  </fields>
               </register>
            </cluster>
            <register>
               <name>BASE</name>
               <description>Ring Buffer Base Register</description>
               <addressOffset>0x30</addressOffset>
               <fields>
