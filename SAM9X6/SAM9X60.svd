                     <bitOffset>0</bitOffset>
                     <bitWidth>10</bitWidth>
                  </field>
               </fields>
            </register>
            <register>
               <name>TAIL</name>
               <description>Ring Buffer Tail Register</description>
               <addressOffset>0x3C</addressOffset>
               <fields>
                  <field>
                     <name>TAIL</name>
                     <description>Ring Buffer Tail Pointer</description>
                     <bitOffset>0</bitOffset>
                     <bitWidth>10</bitWidth>
                  </field>
               </fields>
            </register>
            <cluster>
               <dim>4</dim>
               <dimIncrement>16</dimIncrement>
               <name>GFX2D_CHID[%s]</name>
               <description/>
               <addressOffset>0x40</addressOffset>
               <register>
                  <name>PA</name>
                  <description>Surface Physical Address Register</description>
                  <addressOffset>0x0</addressOffset>
                  <fields>
                     <field>
                        <name>PA</name>
                        <description>Surface Physical Start Address</description>
                        <bitOffset>0</bitOffset>
                        <bitWidth>32</bitWidth>
                     </field>
                  </fields>
               </register>
               <register>
                  <name>PITCH</name>
                  <description>Surface Pitch Register</description>
                  <addressOffset>0x4</addressOffset>
                  <fields>
                     <field>
                        <name>PITCH</name>
                        <description>Surface Pitch</description>
                        <bitOffset>0</bitOffset>
                        <bitWidth>16</bitWidth>
                     </field>
                  </fields>
               </register>
               <register>
                  <name>CFG</name>
                  <description>Surface Configuration Register</description>
                  <addressOffset>0x8</addressOffset>
                  <fields>
                     <field>
                        <name>PF</name>
                        <description>Pixel Format</description>
                        <bitOffset>0</bitOffset>
                        <bitWidth>4</bitWidth>
                        <writeConstraint>
                           <useEnumeratedValues>true</useEnumeratedValues>
                        </writeConstraint>
                        <enumeratedValues>
                           <name>PFSelect</name>
                           <enumeratedValue>
                              <name>A4IDX4</name>
                              <description>4-bit indexed color, with 4-bit alpha value</description>
                              <value>0x0</value>
                           </enumeratedValue>
                           <enumeratedValue>
                              <name>A8</name>
                              <description>8 bits per pixel alpha, with user-defined constant color</description>
                              <value>0x1</value>
                           </enumeratedValue>
                           <enumeratedValue>
                              <name>IDX8</name>
                              <description>8 bits indexed color, uses the Color Look-Up Table to expand to true color</description>
                              <value>0x2</value>
                           </enumeratedValue>
                           <enumeratedValue>
                              <name>A8IDX8</name>
                              <description>8-bit indexed color, with 8-bit alpha value</description>
                              <value>0x3</value>
                           </enumeratedValue>
                           <enumeratedValue>
                              <name>RGB12</name>
                              <description>12 bits per pixel, 4 bits per color channel</description>
                              <value>0x4</value>
                           </enumeratedValue>
                           <enumeratedValue>
                              <name>ARGB16</name>
                              <description>16 bits per pixel with 4-bit width alpha value, and 4 bits per color channel</description>
                              <value>0x5</value>
                           </enumeratedValue>
                           <enumeratedValue>
                              <name>RGB15</name>
                              <description>15 bits per pixel, 5 bits per color channel</description>
                              <value>0x6</value>
                           </enumeratedValue>
                           <enumeratedValue>
                              <name>TRGB16</name>
                              <description>16 bits per pixel, 5 bits for the red and blue channels and 6 bits for the green channel</description>
                              <value>0x7</value>
                           </enumeratedValue>
                           <enumeratedValue>
                              <name>RGBT16</name>
                              <description>16 bits per pixel, with 1 bit for transparency and 5 bits for color channels</description>
                              <value>0x8</value>
                           </enumeratedValue>
                           <enumeratedValue>
                              <name>RGB16</name>
                              <description>16 bits per pixel, 5 bits for the red and blue channels and 6 bits for the green channel</description>
                              <value>0x9</value>
                           </enumeratedValue>
                           <enumeratedValue>
                              <name>RGB24</name>
                              <description>24 bits per pixel, 8 bits for alpha and color channels</description>
                              <value>0xA</value>
                           </enumeratedValue>
                           <enumeratedValue>
                              <name>ARGB32</name>
                              <description>32 bits per pixel, 8 bits for alpha and color channels</description>
                              <value>0xB</value>
                           </enumeratedValue>
                           <enumeratedValue>
                              <name>RGBA32</name>
                              <description>32 bits per pixel, 8 bits for alpha and color channels</description>
                              <value>0xC</value>
                           </enumeratedValue>
                        </enumeratedValues>
                     </field>
                     <field>
                        <name>IDXCX</name>
                        <description>Color Look-Up Table Selection</description>
                        <bitOffset>4</bitOffset>
                        <bitWidth>1</bitWidth>
                     </field>
                  </fields>
               </register>
            </cluster>
         </registers>
      </peripheral>
