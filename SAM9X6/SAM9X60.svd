      <peripheral>
         <name>AES</name>
         <version>6149ZH</version>
         <description>Advanced Encryption Standard</description>
         <baseAddress>0xF0034000</baseAddress>
         <addressBlock>
            <offset>0</offset>
            <size>0xEC</size>
            <usage>registers</usage>
         </addressBlock>
