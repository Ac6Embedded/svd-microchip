               <register>
                  <name>SSR</name>
                  <description>Safety Status Register </description>
                  <addressOffset>0x38</addressOffset>
                  <access>read-only</access>
                  <fields>
                     <field>
                        <name>WPVS</name>
                        <description>Write Protection Violation Status (cleared on read)</description>
                        <bitOffset>0</bitOffset>
                        <bitWidth>1</bitWidth>
                        <writeConstraint>
                           <useEnumeratedValues>true</useEnumeratedValues>
                        </writeConstraint>
                        <enumeratedValues>
                           <name>WPVSSelect</name>
                           <enumeratedValue>
                              <name>WPVS_0</name>
                              <description>No write protection violation has occurred since the last read of TC_SSRx.</description>
                              <value>0</value>
                           </enumeratedValue>
                           <enumeratedValue>
                              <name>WPVS_1</name>
                              <description>A write protection violation has occurred since the last read of TC_SSRx. If this violation is an unauthorized attempt to write a protected register, the associated violation is reported into field WPVSRC.</description>
                              <value>1</value>
                           </enumeratedValue>
                        </enumeratedValues>
                     </field>
                     <field>
                        <name>CGD</name>
                        <description>Clock Glitch Detected (cleared on read)</description>
                        <bitOffset>1</bitOffset>
                        <bitWidth>1</bitWidth>
                        <writeConstraint>
                           <useEnumeratedValues>true</useEnumeratedValues>
                        </writeConstraint>
                        <enumeratedValues>
                           <name>CGDSelect</name>
                           <enumeratedValue>
                              <name>CGD_0</name>
                              <description>The clock monitoring has not been corrupted since the last read of TC_SSRx.</description>
                              <value>0</value>
                           </enumeratedValue>
                           <enumeratedValue>
                              <name>CGD_1</name>
                              <description>The clock monitoring has been corrupted since the last read of TC_SSRx. This flag can be set under abnormal operating conditions.</description>
                              <value>1</value>
                           </enumeratedValue>
                        </enumeratedValues>
                     </field>
                     <field>
                        <name>SEQE</name>
                        <description>Internal Sequencer Error (cleared on read)</description>
                        <bitOffset>2</bitOffset>
                        <bitWidth>1</bitWidth>
                        <writeConstraint>
                           <useEnumeratedValues>true</useEnumeratedValues>
                        </writeConstraint>
                        <enumeratedValues>
                           <name>SEQESelect</name>
                           <enumeratedValue>
                              <name>SEQE_0</name>
                              <description>No internal counter error has occurred since the last read of TC_SSRx. In normal operating conditions, SEQE is cleared.</description>
                              <value>0</value>
                           </enumeratedValue>
                           <enumeratedValue>
                              <name>SEQE_1</name>
                              <description>An internal counter error has occurred since the last read of TC_SSRx. This flag can be set only under abnormal operating conditions resulting in clock glitch, etc. The detection is enabled if TC_CSRx.CLKSTA=1, TC_CMRx.WAVE=1, TC_CMRx.CPCTRG=1 and flag is set if TC_CVx &gt; TC_RCx.</description>
                              <value>1</value>
                           </enumeratedValue>
                        </enumeratedValues>
                     </field>
                     <field>
                        <name>SWE</name>
                        <description>Software Control Error (cleared on read)</description>
                        <bitOffset>3</bitOffset>
                        <bitWidth>1</bitWidth>
                        <writeConstraint>
                           <useEnumeratedValues>true</useEnumeratedValues>
                        </writeConstraint>
                        <enumeratedValues>
                           <name>SWESelect</name>
                           <enumeratedValue>
                              <name>SWE_0</name>
                              <description>No software error has occurred since the last read of TC_SSRx.</description>
                              <value>0</value>
                           </enumeratedValue>
                           <enumeratedValue>
                              <name>SWE_1</name>
                              <description>A software error has occurred since the last read of TC_SSRx. The field SWETYP details the type of software error encountered.</description>
                              <value>1</value>
                           </enumeratedValue>
                        </enumeratedValues>
                     </field>
                     <field>
                        <name>WPVSRC</name>
                        <description>Write Protection Violation Source (cleared on read)</description>
                        <bitOffset>8</bitOffset>
                        <bitWidth>16</bitWidth>
                     </field>
                     <field>
                        <name>SWETYP</name>
                        <description>Software Error Type (cleared on read)</description>
                        <bitOffset>24</bitOffset>
                        <bitWidth>4</bitWidth>
                        <writeConstraint>
                           <useEnumeratedValues>true</useEnumeratedValues>
                        </writeConstraint>
                        <enumeratedValues>
                           <name>SWETYPSelect</name>
                           <enumeratedValue>
                              <name>READ_WO</name>
                              <description>TC Channel x is enabled and a write-only register has been read (Warning).</description>
                              <value>0</value>
                           </enumeratedValue>
                           <enumeratedValue>
                              <name>WRITE_RO</name>
                              <description>TC Channel x is enabled and a write access has been performed on a read-only register (Warning).</description>
                              <value>1</value>
                           </enumeratedValue>
                           <enumeratedValue>
                              <name>UNDEF_RW</name>
                              <description>Access to an undefined address of the TC (Warning).</description>
                              <value>2</value>
                           </enumeratedValue>
                           <enumeratedValue>
                              <name>W_RARB_CAPT</name>
                              <description>TC_RAx or TC_RBx are written while channel is enabled and configured in capture mode (Error).</description>
                              <value>3</value>
                           </enumeratedValue>
                        </enumeratedValues>
                     </field>
                     <field>
                        <name>ECLASS</name>
                        <description>Software Error Class</description>
                        <bitOffset>31</bitOffset>
                        <bitWidth>1</bitWidth>
                        <writeConstraint>
                           <useEnumeratedValues>true</useEnumeratedValues>
                        </writeConstraint>
                        <enumeratedValues>
                           <name>ECLASSSelect</name>
                           <enumeratedValue>
                              <name>WARNING</name>
                              <description>An abnormal access that does not have any impact.</description>
                              <value>0x0</value>
                           </enumeratedValue>
                           <enumeratedValue>
                              <name>ERROR</name>
                              <description>An abnormal access that may have an impact.</description>
                              <value>0x1</value>
                           </enumeratedValue>
                        </enumeratedValues>
                     </field>
                  </fields>
               </register>
