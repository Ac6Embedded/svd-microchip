                           <useEnumeratedValues>true</useEnumeratedValues>
                        </writeConstraint>
                        <enumeratedValues>
                           <name>SAMPASelect</name>
                           <enumeratedValue>
                              <name>ADJ0</name>
                              <description>16x Over-sampling = 7-8-9; 8x Over-sampling = 3-4-5</description>
                              <value>0x0</value>
                           </enumeratedValue>
                           <enumeratedValue>
                              <name>ADJ1</name>
                              <description>16x Over-sampling = 9-10-11; 8x Over-sampling = 4-5-6</description>
                              <value>0x1</value>
                           </enumeratedValue>
                           <enumeratedValue>
                              <name>ADJ2</name>
                              <description>16x Over-sampling = 11-12-13; 8x Over-sampling = 5-6-7</description>
                              <value>0x2</value>
                           </enumeratedValue>
                           <enumeratedValue>
                              <name>ADJ3</name>
                              <description>16x Over-sampling = 13-14-15; 8x Over-sampling = 6-7-8</description>
                              <value>0x3</value>
                           </enumeratedValue>
                        </enumeratedValues>
                     </field>
                     <field>
